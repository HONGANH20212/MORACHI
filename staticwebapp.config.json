{
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "globalHeaders": {
    "content-security-policy": "default-src 'self' https: data: 'unsafe-inline' 'unsafe-eval';"
  },
  "hostingExtensions": {
    "redirects": [
      {
        "forwardingProtocol": "http",
        "redirect": "https://www.morachi.com.vn",
        "statusCode": 301
      }
    ]
  }
}